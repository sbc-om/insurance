---
import i18next from "../lib/i18n";
import { ViewTransitions } from "astro:transitions";
import WhatsAppIcon from "../components/WhatsAppIcon";
import "overlayscrollbars/overlayscrollbars.css";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const { title, description, lang = "en" } = Astro.props;
await i18next.changeLanguage(lang);

const pageTitle = title || i18next.t("site.title");
const pageDescription = description || i18next.t("site.description");
const whatsappLink = "https://api.whatsapp.com/send?phone=96891200634";
---

<!doctype html>
<html lang={lang} dir={lang === "ar" || lang === "fa" ? "rtl" : "ltr"} data-overlayscrollbars-initialize>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#1a365d" />
    <link rel="icon" type="image/png" sizes="32x32" href="/pwa/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/pwa/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <ViewTransitions />
    <title>{pageTitle}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Vazirmatn:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body data-overlayscrollbars-initialize>
    <slot />

    <a
      href={whatsappLink}
      class="whatsapp-float"
      id="whatsapp-float"
      style="right:24px;bottom:24px;width:58px;height:58px;min-width:58px;min-height:58px;max-width:58px;max-height:58px;padding:0;"
      aria-label="Chat on WhatsApp"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span class="whatsapp-float-icon" aria-hidden="true">
        <WhatsAppIcon />
      </span>
    </a>

    <script is:inline>
      (() => {
        const storageKey = 'whatsapp-float-position';
        const button = document.getElementById('whatsapp-float');
        if (!button || button.dataset.dragBound === 'true') return;
        button.dataset.dragBound = 'true';

        const margin = 16;
        const dragThreshold = 6;
        let activePointerId = null;

        const getPoint = (event) => {
          return { x: event.clientX, y: event.clientY };
        };

        const applyPosition = (x, y) => {
          const maxX = window.innerWidth - button.offsetWidth - margin;
          const maxY = window.innerHeight - button.offsetHeight - margin;
          const nextX = Math.min(Math.max(margin, x), Math.max(margin, maxX));
          const nextY = Math.min(Math.max(margin, y), Math.max(margin, maxY));

          button.style.right = 'auto';
          button.style.bottom = 'auto';
          button.style.left = `${nextX}px`;
          button.style.top = `${nextY}px`;
        };

        const savePosition = () => {
          localStorage.setItem(
            storageKey,
            JSON.stringify({
              left: parseFloat(button.style.left),
              top: parseFloat(button.style.top),
            })
          );
        };

        const getCurrentPosition = () => ({
          left: parseFloat(button.style.left || '0'),
          top: parseFloat(button.style.top || '0'),
        });

        const setDefaultPosition = () => {
          const defaultLeft = window.innerWidth - button.offsetWidth - 24;
          const defaultTop = window.innerHeight - button.offsetHeight - 24;
          applyPosition(defaultLeft, defaultTop);
        };

        requestAnimationFrame(() => {
          try {
            const saved = localStorage.getItem(storageKey);
            if (saved) {
              const { left, top } = JSON.parse(saved);
              applyPosition(left, top);
            } else {
              setDefaultPosition();
            }
          } catch {
            setDefaultPosition();
          }
        });

        let isDragging = false;
        let dragStarted = false;
        let moved = false;
        let suppressClick = false;
        let startPointerX = 0;
        let startPointerY = 0;
        let startLeft = 0;
        let startTop = 0;

        const startDrag = (event) => {
          if ('button' in event && event.button !== 0) {
            return;
          }

          event.preventDefault();
          activePointerId = event.pointerId;
          button.setPointerCapture(event.pointerId);
          const point = getPoint(event);
          startPointerX = point.x;
          startPointerY = point.y;
          const currentPosition = getCurrentPosition();
          startLeft = currentPosition.left;
          startTop = currentPosition.top;
          dragStarted = true;
          moved = false;
        };

        const handleDragMove = (event) => {
          if (!dragStarted || activePointerId !== event.pointerId) return;

          const point = getPoint(event);
          const deltaX = point.x - startPointerX;
          const deltaY = point.y - startPointerY;

          if (!isDragging) {
            if (Math.hypot(deltaX, deltaY) < dragThreshold) {
              return;
            }
            isDragging = true;
            suppressClick = true;
            button.classList.add('is-dragging');
            document.body.classList.add('whatsapp-dragging');
          }

          event.preventDefault();
          moved = true;
          applyPosition(startLeft + deltaX, startTop + deltaY);
        };

        const endDrag = (event) => {
          if (!dragStarted || activePointerId !== event.pointerId) return;

          if (isDragging || moved) {
            savePosition();
          }

          dragStarted = false;
          isDragging = false;
          moved = false;
          activePointerId = null;
          button.classList.remove('is-dragging');
          document.body.classList.remove('whatsapp-dragging');

          if (button.hasPointerCapture(event.pointerId)) {
            button.releasePointerCapture(event.pointerId);
          }

          window.setTimeout(() => {
            suppressClick = false;
          }, 120);
        };

        button.addEventListener('dragstart', (event) => {
          event.preventDefault();
        });

        button.addEventListener('pointerdown', startDrag);
        button.addEventListener('pointermove', handleDragMove);
        button.addEventListener('pointerup', endDrag);
        button.addEventListener('pointercancel', endDrag);
        button.addEventListener('lostpointercapture', (event) => {
          if (dragStarted && activePointerId === event.pointerId) {
            endDrag(event);
          }
        });

        button.addEventListener('click', (event) => {
          if (suppressClick) {
            event.preventDefault();
            event.stopPropagation();
          }
        });

        window.addEventListener('resize', () => {
          if (button.style.left && button.style.top) {
            applyPosition(parseFloat(button.style.left), parseFloat(button.style.top));
            savePosition();
          } else {
            setDefaultPosition();
          }
        });
      })();
    </script>

    <script>
      import { registerSW } from 'virtual:pwa-register';

      registerSW({
		immediate: true,
	  });
    </script>

    <script>
      import { OverlayScrollbars } from 'overlayscrollbars';
      import type { PartialOptions } from 'overlayscrollbars';

      declare global {
        interface Window {
          __sbcOverlayScrollbarsBound?: boolean;
        }
      }

      const overlayTheme = {
        scrollbars: {
          theme: 'os-theme-sbc',
          autoHide: 'leave',
          autoHideDelay: 450,
          clickScroll: true,
          dragScroll: true,
        },
      } satisfies PartialOptions;

      const isScrollableElement = (element: Element): element is HTMLElement => {
        if (!(element instanceof HTMLElement)) return false;
        if (element === document.body) return true;
        if (element instanceof HTMLTextAreaElement) return true;

        const style = window.getComputedStyle(element);
        const overflowValue = `${style.overflow} ${style.overflowX} ${style.overflowY}`;
        return /(auto|scroll|overlay)/.test(overflowValue);
      };

      const initOverlayScrollbars = () => {
        if (!(document.body instanceof HTMLElement)) return;

        OverlayScrollbars(document.body, overlayTheme);

        document.querySelectorAll('*').forEach((element: Element) => {
          if (isScrollableElement(element)) {
            OverlayScrollbars(element, overlayTheme);
          }
        });
      };

      if (!window.__sbcOverlayScrollbarsBound) {
        window.__sbcOverlayScrollbarsBound = true;

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initOverlayScrollbars);
        } else {
          initOverlayScrollbars();
        }

        document.addEventListener('astro:page-load', initOverlayScrollbars);
        document.addEventListener('astro:after-swap', initOverlayScrollbars);
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #1a365d;
    --color-secondary: #2c5282;
    --color-accent: #d4af37;
    --color-text: #1a202c;
    --color-text-light: #4a5568;
    --color-bg: #ffffff;
    --color-bg-light: #f7fafc;
    --max-width: 1280px;
    --os-size: 11px;
    --os-padding-perpendicular: 2px;
    --os-padding-axis: 2px;
    --os-handle-border-radius: 999px;
    --os-handle-bg: rgba(26, 54, 93, 0.46);
    --os-handle-bg-hover: rgba(26, 54, 93, 0.66);
    --os-handle-bg-active: rgba(26, 54, 93, 0.84);
    --os-track-bg: rgba(26, 54, 93, 0.08);
  }

  .os-theme-sbc {
    --os-size: 11px;
    --os-handle-perpendicular-size: 100%;
    --os-track-border-radius: 999px;
    --os-track-bg: rgba(26, 54, 93, 0.08);
    --os-handle-bg: rgba(26, 54, 93, 0.46);
    --os-handle-bg-hover: rgba(26, 54, 93, 0.66);
    --os-handle-bg-active: rgba(26, 54, 93, 0.84);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: system-ui, sans-serif;
    scroll-behavior: smooth;
    width: 100%;
    overflow-x: hidden;
  }

  html,
  body {
    min-height: 100%;
  }

  html:lang(en) {
    font-family: 'Inter', sans-serif;
  }

  html:lang(ar),
  html:lang(fa) {
    font-family: 'Vazirmatn', sans-serif;
  }

  body {
    color: var(--color-text);
    background-color: var(--color-bg);
    line-height: 1.6;
    width: 100%;
    overflow-x: hidden;
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }

  h1, h2, h3, h4, h5, h6 {
    line-height: 1.2;
    font-weight: 700;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section {
    padding: 4rem 0;
  }

  @media (min-width: 768px) {
    .section {
      padding: 6rem 0;
    }
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    border-radius: 0.5rem;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .btn-primary {
    background-color: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    background-color: var(--color-secondary);
    transform: translateY(-2px);
  }

  .btn-outline {
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
  }

  .btn-outline:hover {
    background-color: var(--color-primary);
    color: white;
  }

  .page-hero {
    padding: 5rem 0 3rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    color: white;
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 0.5rem;
  }

  .page-hero p {
    max-width: 800px;
    margin: 0 auto;
    opacity: 0.9;
  }

  .page-content {
    padding: 4rem 0;
  }


  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .card {
    background: white;
    border-radius: 0.75rem;
    padding: 1.5rem;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
  }

  .card h3 {
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .two-col {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    align-items: start;
  }

  .section-title-alt {
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .muted {
    color: var(--color-text-light);
  }

  .form {
    display: grid;
    gap: 1rem;
  }

  .form input,
  .form textarea {
    padding: 0.75rem 1rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    font-family: inherit;
  }

  .form textarea {
    min-height: 140px;
    resize: vertical;
  }

  .badge-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .badge {
    background: var(--color-bg-light);
    border: 1px solid #e2e8f0;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    font-size: 0.9rem;
  }

  .whatsapp-float {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 58px;
    min-width: 58px;
    max-width: 58px;
    height: 58px;
    min-height: 58px;
    max-height: 58px;
    padding: 0 !important;
    border-radius: 999px;
    background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);
    color: white;
    box-shadow: 0 18px 36px rgba(18, 140, 126, 0.32);
    cursor: grab;
    user-select: none;
    touch-action: none;
    overflow: hidden;
    line-height: 0;
  }

  .whatsapp-float.is-dragging {
    cursor: grabbing;
    box-shadow: 0 24px 48px rgba(18, 140, 126, 0.4);
    transform: scale(1.04);
  }

  .whatsapp-float-icon {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0;
  }

  .whatsapp-float-icon svg {
    width: 30px !important;
    height: 30px !important;
    display: block;
    flex-shrink: 0;
  }

  body.whatsapp-dragging {
    user-select: none;
  }

  @media (max-width: 640px) {
    .whatsapp-float {
      width: 54px;
      min-width: 54px;
      max-width: 54px;
      height: 54px;
      min-height: 54px;
      max-height: 54px;
    }

    .whatsapp-float-icon :global(svg) {
      width: 28px !important;
      height: 28px !important;
    }
  }
</style>
