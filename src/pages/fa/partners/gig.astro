---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
const lang = "fa";
---

<Layout title="بیمه GIG - گروه بیمه خلیج | بیمه" lang={lang}>
  <Header lang={lang} />
  
  <main dir="rtl">
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/gig.png" alt="GIG Insurance" class="partner-logo" />
          <div class="partner-intro">
            <h1>GIG - گروه بیمه خلیج</h1>
            <p class="tagline">بزرگترین شبکه بیمه‌ای در خاورمیانه و شمال آفریقا</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>درباره GIG</h2>
        <div class="about-content">
          <p>گروه بیمه خلیج (GIG) بزرگترین شرکت بیمه در کویت و یکی از بزرگترین‌ها در خاورمیانه و شمال آفریقا است. با عملیات در چندین کشور، GIG خدمات جامع بیمه و بیمه اتکایی را از طریق شبکه‌ای از شرکت‌های تابعه و وابسته ارائه می‌دهد.</p>
          <p>GIG دارای رتبه‌بندی مالی قوی است و به محصولات نوآورانه، خدمات عالی مشتری و تعهد به سهامداران شناخته شده است. این گروه طیف کاملی از راه‌حل‌های بیمه‌ای را برای افراد، SMEها و شرکت‌ها ارائه می‌دهد.</p>
          
          <div class="stats-grid">
            <div class="stat-card">
              <span class="stat-number">A</span>
              <span class="stat-label">رتبه A.M. Best</span>
            </div>
            <div class="stat-card">
              <span class="stat-number">+۶۰</span>
              <span class="stat-label">سال برتری</span>
            </div>
            <div class="stat-card">
              <span class="stat-number">+۱۰</span>
              <span class="stat-label">کشور</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>محصولات بیمه‌ای</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>بیمه خودرو</h3>
            <ul>
              <li>پوشش جامع خودرو</li>
              <li>مسئولیت شخص ثالث</li>
              <li>بیمه ناوگان تجاری</li>
              <li>حفاظت خودروهای لوکس</li>
              <li>کمک جاده‌ای ۲۴/۷</li>
              <li>شبکه تعمیرگاه‌های نمایندگی</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>بیمه درمان</h3>
            <ul>
              <li>طرح‌های بهداشتی فردی</li>
              <li>بیمه درمان گروهی</li>
              <li>پوشش درمان بین‌المللی</li>
              <li>مدیریت بیماری‌های مزمن</li>
              <li>طرح‌های دندانپزشکی و چشم‌پزشکی</li>
              <li>برنامه‌های تندرستی</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>بیمه اموال</h3>
            <ul>
              <li>آتش‌سوزی و خطرات جانبی</li>
              <li>تمام خطر اموال</li>
              <li>توقف کسب‌وکار</li>
              <li>تمام خطر صنعتی</li>
              <li>خرابی ماشین‌آلات</li>
              <li>تجهیزات الکترونیکی</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">⚓</div>
            <h3>بیمه دریایی</h3>
            <ul>
              <li>بیمه کالای دریایی</li>
              <li>بدنه و ماشین‌آلات</li>
              <li>مسئولیت دریایی</li>
              <li>ترانزیت داخلی</li>
              <li>بنادر و ترمینال‌ها</li>
              <li>بیمه قایق تفریحی</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">💼</div>
            <h3>بیمه مسئولیت</h3>
            <ul>
              <li>مسئولیت عمومی</li>
              <li>غرامت حرفه‌ای</li>
              <li>مدیران و مسئولان</li>
              <li>مسئولیت محصول</li>
              <li>مسئولیت سایبری</li>
              <li>شیوه‌های استخدام</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🛡️</div>
            <h3>بیمه عمر و پس‌انداز</h3>
            <ul>
              <li>بیمه عمر زمان‌دار</li>
              <li>طرح‌های عمر کامل</li>
              <li>محصولات واحد مرتبط</li>
              <li>بیمه عمر گروهی</li>
              <li>بازنشستگی و پس‌انداز</li>
              <li>بیمه اعتبار زندگی</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>چرا GIG را انتخاب کنید؟</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>رهبر منطقه‌ای</h4>
            <p>بزرگترین شبکه بیمه‌ای در MENA</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>قدرت مالی</h4>
            <p>رتبه A قوی از آژانس‌های بین‌المللی</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>تخصص جهانی</h4>
            <p>مشارکت‌های بیمه اتکایی بین‌المللی</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>نوآوری</h4>
            <p>راه‌حل‌های بیمه‌ای دیجیتال-اول</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>برتری GIG را تجربه کنید</h2>
        <p>پوشش جامع از بیمه‌گر پیشرو منطقه دریافت کنید</p>
        <a href="/fa/contact" class="cta-button">تماس با ما</a>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-right: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    right: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
