---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
const lang = "fa";
---

<Layout title="بیمه مسقط | بیمه" lang={lang}>
  <Header lang={lang} />
  
  <main>
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/muscat-insurance.png" alt="Muscat Insurance Logo" class="partner-logo" />
          <div class="partner-intro">
            <h1>بیمه مسقط</h1>
            <p class="tagline">شریک مطمئن در حفاظت از آینده شما از سال ۱۹۸۴</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>درباره بیمه مسقط</h2>
        <p>شرکت بیمه مسقط یکی از شرکت‌های پیشرو در صنعت بیمه سلطنت عمان است که در سال ۱۹۸۴ تأسیس شده و مجموعه‌ای جامع از راه‌حل‌های بیمه‌ای را برای افراد و شرکت‌ها ارائه می‌دهد.</p>
        <p>این شرکت تحت مجوز سازمان بازار سرمایه سلطنت عمان فعالیت می‌کند و به بالاترین استانداردهای شفافیت و صداقت در تمام معاملات خود پایبند است. شرکت دارای شبکه گسترده‌ای از شعب و مراکز خدمات در سراسر کشور است.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">+۴۰</span>
            <span class="stat-label">سال تجربه</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">+۱۰۰K</span>
            <span class="stat-label">مشتری راضی</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">+۵۰</span>
            <span class="stat-label">شعبه و مرکز خدمات</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>محصولات بیمه‌ای</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>بیمه خودرو</h3>
            <ul>
              <li>بیمه جامع خودرو</li>
              <li>بیمه شخص ثالث</li>
              <li>بیمه خودروهای لوکس</li>
              <li>بیمه ناوگان خودرویی</li>
              <li>خدمات کمک جاده‌ای ۲۴ ساعته</li>
              <li>پوشش حوادث شخصی راننده</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>بیمه درمان</h3>
            <ul>
              <li>طرح‌های بیمه درمانی فردی</li>
              <li>بیمه درمان خانواده</li>
              <li>بیمه درمان شرکتی</li>
              <li>پوشش درمان داخل و خارج عمان</li>
              <li>پوشش بیماری‌های مزمن</li>
              <li>برنامه‌های دندانپزشکی و چشم</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>بیمه اموال</h3>
            <ul>
              <li>بیمه منزل و ساختمان</li>
              <li>بیمه اثاثیه منزل</li>
              <li>بیمه آتش‌سوزی</li>
              <li>بیمه سرقت</li>
              <li>بیمه بلایای طبیعی</li>
              <li>بیمه مسئولیت اشخاص ثالث</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">✈️</div>
            <h3>بیمه سفر</h3>
            <ul>
              <li>بیمه سفر فردی</li>
              <li>بیمه سفر خانوادگی</li>
              <li>بیمه سفرهای چندگانه</li>
              <li>پوشش کنسلی سفر</li>
              <li>پوشش گم شدن چمدان</li>
              <li>کمک پزشکی اضطراری</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>بیمه کسب‌وکار</h3>
            <ul>
              <li>بیمه مسئولیت حرفه‌ای</li>
              <li>بیمه توقف کسب‌وکار</li>
              <li>بیمه مسئولیت عمومی</li>
              <li>بیمه غرامت کارگران</li>
              <li>بیمه کالا و حمل‌ونقل</li>
              <li>بیمه تجهیزات و ماشین‌آلات</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🛡️</div>
            <h3>بیمه زندگی</h3>
            <ul>
              <li>بیمه عمر فردی</li>
              <li>بیمه عمر گروهی</li>
              <li>بیمه حمایت خانواده</li>
              <li>بیمه بازنشستگی و پس‌انداز</li>
              <li>بیمه بازپرداخت وام</li>
              <li>بیمه حوادث شخصی</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>چرا بیمه مسقط را انتخاب کنید؟</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>تجربه طولانی</h4>
            <p>بیش از ۴۰ سال تجربه در بازار بیمه عمان</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>تسویه سریع</h4>
            <p>پردازش خسارت با سرعت و کارایی بالا</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>قیمت‌های رقابتی</h4>
            <p>راه‌حل‌های بیمه‌ای با قیمت مناسب برای همه</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>پشتیبانی ۲۴/۷</h4>
            <p>تیم خدمات مشتری در دسترس شبانه‌روزی</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>اطلاعات بیشتر درباره بیمه مسقط</h2>
        <p>برای دریافت اطلاعات عمومی درباره این شرکت با ما تماس بگیرید</p>
        <a href="/fa/contact" class="cta-button">تماس برای اطلاعات</a>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-right: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    right: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
