---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
const lang = "fa";
---

<Layout title="بیمه تکافل عمان | بیمه" lang={lang}>
  <Header lang={lang} />
  
  <main>
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/takaful-oman.png" alt="Takaful Oman Insurance Logo" class="partner-logo" />
          <div class="partner-intro">
            <h1>تکافل عمان</h1>
            <p class="tagline">راهکارهای پیشرو بیمه اسلامی در عمان</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>درباره تکافل عمان</h2>
        <p>تکافل عمان یکی از شرکت‌های پیشرو در ارائه راهکارهای بیمه اسلامی (تکافل) در سلطنت عمان است. این شرکت خدمات بیمه‌ای کاملاً منطبق با شریعت اسلامی ارائه می‌دهد و تحت نظارت هیئت شرعی متشکل از علمای برجسته فعالیت می‌کند.</p>
        <p>با پایبندی به اصول اسلامی همکاری و کمک متقابل، تکافل عمان راه‌حل‌های جامع بیمه‌ای را برای افراد، خانواده‌ها و کسب‌وکارها فراهم می‌کند. محصولات این شرکت بر پایه اصل تقسیم ریسک طراحی شده‌اند، نه انتقال ریسک.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">۱۰۰٪</span>
            <span class="stat-label">منطبق با شریعت</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">+۷۵K</span>
            <span class="stat-label">مشارکان</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">MSM</span>
            <span class="stat-label">شرکت بورسی</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>محصولات تکافل</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>تکافل خودرو</h3>
            <ul>
              <li>تکافل جامع خودرو</li>
              <li>مسئولیت شخص ثالث</li>
              <li>پوشش کارت نارنجی (خلیج)</li>
              <li>بیمه حوادث شخصی</li>
              <li>تعمیرات نمایندگی</li>
              <li>کمک جاده‌ای اضطراری</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>تکافل سلامت</h3>
            <ul>
              <li>تکافل سلامت فردی</li>
              <li>طرح‌های تکافل خانواده</li>
              <li>تکافل سلامت گروهی</li>
              <li>سرپایی و بستری</li>
              <li>پوشش بارداری</li>
              <li>بیماری‌های مزمن</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>تکافل اموال</h3>
            <ul>
              <li>تکافل منزل</li>
              <li>آتش‌سوزی و خطرات جانبی</li>
              <li>حفاظت محتویات</li>
              <li>بلایای طبیعی</li>
              <li>مسئولیت شخصی</li>
              <li>پوشش نیروی خدماتی</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">👨‍👩‍👧‍👦</div>
            <h3>تکافل خانواده</h3>
            <ul>
              <li>حفاظت عمر اسلامی</li>
              <li>طرح‌های پس‌انداز</li>
              <li>طرح‌های تحصیل</li>
              <li>بیماری‌های بحرانی</li>
              <li>حوادث شخصی</li>
              <li>پوشش حج و عمره</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>تکافل کسب‌وکار</h3>
            <ul>
              <li>تمام خطر اموال</li>
              <li>مسئولیت حرفه‌ای</li>
              <li>غرامت کارگران</li>
              <li>بیمه پول</li>
              <li>مسئولیت عمومی</li>
              <li>حوادث گروهی</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">⚓</div>
            <h3>تکافل دریایی</h3>
            <ul>
              <li>تکافل کالا</li>
              <li>بدنه و ماشین‌آلات</li>
              <li>پوشش حمل بار</li>
              <li>ذخیره انبار</li>
              <li>مسئولیت دریایی</li>
              <li>قایق و کشتی</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>چرا تکافل عمان را انتخاب کنید؟</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">☪</span>
            <h4>نظارت شرعی</h4>
            <p>هیئت شرعی مستقل برای تضمین انطباق با شریعت اسلامی</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>تقسیم مازاد</h4>
            <p>مشارکان در مازاد بر اساس مدل تکافل سهیم هستند</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>سرمایه‌گذاری اخلاقی</h4>
            <p>تمام سرمایه‌گذاری‌ها در ابزارهای منطبق با شریعت</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>خدمات محلی</h4>
            <p>خدمات اختصاصی در سراسر عمان با تخصص محلی</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>اطلاعات بیشتر درباره تکافل عمان</h2>
        <p>برای راهکارهای تکافل اخلاقی با ما تماس بگیرید</p>
        <a href="/fa/contact" class="cta-button">تماس برای اطلاعات</a>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-right: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    right: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
