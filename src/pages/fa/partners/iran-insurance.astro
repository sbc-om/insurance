---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
const lang = "fa";
---

<Layout title="بیمه ایران | بیمه" lang={lang}>
  <Header lang={lang} />
  
  <main>
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/iran-insurance.png" alt="Iran Insurance Logo" class="partner-logo" />
          <div class="partner-intro">
            <h1>بیمه ایران</h1>
            <p class="tagline">بزرگترین و قدیمی‌ترین شرکت بیمه ایران</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>درباره بیمه ایران</h2>
        <p>شرکت سهامی بیمه ایران در سال ۱۳۱۴ تأسیس شد و به عنوان اولین و بزرگترین شرکت بیمه در ایران شناخته می‌شود. این شرکت با بیش از ۹۰ سال تجربه، طیف کاملی از محصولات بیمه‌ای را برای افراد و شرکت‌ها ارائه می‌دهد.</p>
        <p>بیمه ایران با شبکه گسترده‌ای از نمایندگی‌ها و شعب در سراسر کشور و حضور بین‌المللی، خدمات بیمه‌ای جامع با بالاترین کیفیت ارائه می‌دهد. این شرکت دارای بیشترین سهم بازار در صنعت بیمه ایران است.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">+۹۰</span>
            <span class="stat-label">سال سابقه</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">+۳K</span>
            <span class="stat-label">شعبه و نمایندگی</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">+۳۰٪</span>
            <span class="stat-label">سهم بازار</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>محصولات بیمه‌ای</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>بیمه خودرو</h3>
            <ul>
              <li>بیمه بدنه اتومبیل</li>
              <li>بیمه شخص ثالث</li>
              <li>بیمه حوادث سرنشین</li>
              <li>بیمه مسئولیت راننده</li>
              <li>بیمه ناوگان</li>
              <li>خدمات امداد خودرو</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>بیمه درمان</h3>
            <ul>
              <li>بیمه تکمیلی درمان</li>
              <li>بیمه درمان گروهی</li>
              <li>بیمه درمان انفرادی</li>
              <li>پوشش بیمارستانی</li>
              <li>پوشش سرپایی</li>
              <li>بیمه دندانپزشکی</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🛡️</div>
            <h3>بیمه عمر</h3>
            <ul>
              <li>بیمه عمر و سرمایه‌گذاری</li>
              <li>بیمه عمر زمان‌دار</li>
              <li>بیمه عمر مانده بدهکار</li>
              <li>بیمه تأمین آتیه</li>
              <li>بیمه جامع زندگی</li>
              <li>بیمه عمر گروهی</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>بیمه اموال</h3>
            <ul>
              <li>بیمه آتش‌سوزی</li>
              <li>بیمه منازل مسکونی</li>
              <li>بیمه زلزله</li>
              <li>بیمه سرقت</li>
              <li>بیمه واحدهای تجاری</li>
              <li>بیمه صنعتی</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">⚓</div>
            <h3>بیمه باربری</h3>
            <ul>
              <li>بیمه حمل داخلی</li>
              <li>بیمه حمل بین‌المللی</li>
              <li>بیمه کالای صادراتی</li>
              <li>بیمه کالای وارداتی</li>
              <li>بیمه کشتی</li>
              <li>بیمه هواپیما</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">👷</div>
            <h3>بیمه مهندسی</h3>
            <ul>
              <li>بیمه تمام خطر پیمانکاران</li>
              <li>بیمه تمام خطر نصب</li>
              <li>بیمه ماشین‌آلات</li>
              <li>بیمه شکست ماشین‌آلات</li>
              <li>بیمه تجهیزات الکترونیکی</li>
              <li>بیمه عدم‌النفع</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>چرا بیمه ایران را انتخاب کنید؟</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>قدمت و اعتبار</h4>
            <p>بیش از ۹۰ سال تجربه در صنعت بیمه</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>شبکه گسترده</h4>
            <p>بیش از ۳۰۰۰ شعبه و نمایندگی</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>توان مالی</h4>
            <p>قوی‌ترین پشتوانه مالی در صنعت</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>تسویه سریع</h4>
            <p>پرداخت به موقع خسارات</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>اطلاعات بیشتر درباره بیمه ایران</h2>
        <p>اطمینان و آرامش خاطر با بزرگترین بیمه‌گر کشور</p>
        <a href="/fa/contact" class="cta-button">تماس برای اطلاعات</a>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-right: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    right: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
