---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import i18next from "../../lib/i18n";

await i18next.changeLanguage("fa");
---

<Layout title="بیمه منزل" lang="fa">
  <Header lang="fa" />

  <main dir="rtl">
    <section class="page-hero">
      <div class="container">
        <h1>بیمه منزل</h1>
        <p>از خانه و محتویات آن با پوشش جامع محافظت کنید.</p>
      </div>
    </section>

    <section class="page-content">
      <div class="container">
        <div class="content-grid">
          <div class="main-content">
            <h2 class="section-title-alt">خانه خود را ایمن کنید</h2>
            <p class="muted">خانه شما بزرگ‌ترین سرمایه‌گذاری شماست. آن را از آتش‌سوزی، سرقت، بلایای طبیعی و موارد بیشتر با بیمه منزل سفارشی محافظت کنید که ملک و محتویات شما را پوشش می‌دهد.</p>

            <h3 style="margin-top:2rem;">بیمه چه چیزهایی را پوشش می‌دهد؟</h3>
            <div class="card-grid" style="margin-top:1rem;">
              <div class="card">
                <h4>ساختمان</h4>
                <ul class="check-list">
                  <li>خسارت آتش‌سوزی و انفجار</li>
                  <li>بلایای طبیعی</li>
                  <li>خسارت آب</li>
                  <li>تعمیرات ساختاری</li>
                </ul>
              </div>
              <div class="card">
                <h4>محتویات و اموال</h4>
                <ul class="check-list">
                  <li>مبلمان و لوازم خانگی</li>
                  <li>الکترونیک و اشیای گران‌بها</li>
                  <li>سرقت و دزدی</li>
                  <li>هزینه جایگزینی</li>
                </ul>
              </div>
              <div class="card">
                <h4>حفاظت مسئولیت</h4>
                <ul class="check-list">
                  <li>آسیب به اشخاص ثالث</li>
                  <li>خسارت به اموال دیگران</li>
                  <li>هزینه‌های حقوقی</li>
                  <li>پوشش کارکنان خانگی</li>
                </ul>
              </div>
            </div>

            <h3 style="margin-top:2rem;">پوشش‌های اختیاری</h3>
            <ul class="feature-list">
              <li><strong>پوشش همه‌جانبه:</strong> محافظت از اشیای گران‌بها در داخل و خارج از خانه</li>
              <li><strong>اسکان جایگزین:</strong> اقامت موقت اگر خانه غیرقابل سکونت شود</li>
              <li><strong>حیاط و فضای باز:</strong> پوشش سازه‌های خارجی و محوطه‌سازی</li>
              <li><strong>شیشه و بهداشتی:</strong> پنجره‌ها، آینه‌ها و تأسیسات</li>
            </ul>

            <h3 style="margin-top:2rem;">چرا بیمه را انتخاب کنید؟</h3>
            <p class="muted">بیمه‌نامه‌ها را از شرکت‌های بیمه معتبر مقایسه کنید. پیشنهادات سفارشی بر اساس ارزش و موقعیت خانه دریافت کنید. طرح‌های پرداخت منعطف موجود است.</p>
          </div>

          <aside class="sidebar">
            <div class="card cta-card">
              <h3>اطلاعات بیشتری نیاز دارید؟</h3>
              <p>برای دریافت اطلاعات عمومی درباره این دسته‌بندی با ما تماس بگیرید.</p>
              <a href="/fa/contact" class="btn btn-primary">تماس با ما</a>
            </div>

            <div class="card" style="margin-top:1rem;">
              <h4>کمک می‌خواهید؟</h4>
              <p style="font-size:0.9rem;">تماس بگیرید یا پیام دهید</p>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="fa" />
</Layout>

<style>
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
  }

  .main-content h3 {
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .check-list {
    list-style: none;
    padding: 0;
  }

  .check-list li {
    padding: 0.4rem 0;
    padding-right: 1.5rem;
    position: relative;
  }

  .check-list li::before {
    content: "✓";
    position: absolute;
    right: 0;
    color: var(--color-accent);
    font-weight: bold;
  }

  .feature-list {
    list-style: none;
    padding: 0;
  }

  .feature-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-bg-light);
  }

  .feature-list li:last-child {
    border-bottom: none;
  }

  .sidebar {
    position: sticky;
    top: 100px;
  }

  .cta-card {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    color: white;
    text-align: center;
  }

  .cta-card h3 {
    color: white;
    margin-bottom: 0.5rem;
  }

  .cta-card p {
    margin-bottom: 1.5rem;
    opacity: 0.9;
  }

  @media (max-width: 968px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .sidebar {
      position: static;
    }
  }
</style>
