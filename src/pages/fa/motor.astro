---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import i18next from "../../lib/i18n";

await i18next.changeLanguage("fa");
---

<Layout title="بیمه خودرو" lang="fa">
  <Header lang="fa" />

  <main dir="rtl">
    <section class="page-hero">
      <div class="container hero-container">
        <h1>بیمه خودرو</h1>
        <div class="hero-visual">
          <img src="/images/motor-hero.png" alt="محافظت بیمه خودرو" class="hero-image" />
        </div>
        <p>پوشش جامع و شخص ثالث برای خودرو شما.</p>
      </div>
    </section>

    <section class="page-content">
      <div class="container">
        <div class="content-grid">
          <div class="main-content">
            <h2 class="section-title-alt">با اطمینان رانندگی کنید</h2>
            <p class="muted">این بخش اطلاعات عمومی درباره دسته‌بندی‌های رایج بیمه خودرو، از جمله پوشش جامع و شخص ثالث، ارائه می‌دهد تا بازدیدکنندگان با گزینه‌های متداول در عمان آشنا شوند.</p>

            <h3 style="margin-top:2rem;">بیمه چه چیزهایی را پوشش می‌دهد؟</h3>
            <div class="card-grid" style="margin-top:1rem;">
              <div class="card">
                <h4>شخص ثالث</h4>
                <ul class="check-list">
                  <li>مسئولیت در قبال دیگران</li>
                  <li>رعایت الزامات قانونی</li>
                  <li>قیمت‌های مناسب</li>
                </ul>
              </div>
              <div class="card">
                <h4>جامع</h4>
                <ul class="check-list">
                  <li>خودرو شما + شخص ثالث</li>
                  <li>سرقت و آتش‌سوزی</li>
                  <li>بلایای طبیعی</li>
                  <li>پوشش‌های اختیاری</li>
                </ul>
              </div>
            </div>

            <h3 style="margin-top:2rem;">پوشش‌های اختیاری</h3>
            <ul class="feature-list">
              <li><strong>تعمیر نمایندگی:</strong> تعمیر خودرو در نمایندگی‌های مجاز</li>
              <li><strong>امداد جاده‌ای:</strong> پشتیبانی ۲۴ ساعته در هر مکان</li>
              <li><strong>پوشش کشورهای خلیج:</strong> رانندگی امن در کشورهای شورای همکاری خلیج</li>
              <li><strong>حوادث شخصی:</strong> محافظت اضافی برای شما</li>
            </ul>

            <h3 style="margin-top:2rem;">درباره این دسته‌بندی</h3>
            <p class="muted">اطلاعات این صفحه صرفاً برای معرفی ارائه شده است و هدف آن کمک به کاربران برای درک بهتر ویژگی‌های متداول بیمه خودرو است.</p>
          </div>

          <aside class="sidebar">
            <div class="card cta-card">
              <h3>اطلاعات بیشتری نیاز دارید؟</h3>
              <p>برای دریافت اطلاعات عمومی درباره این دسته‌بندی با ما تماس بگیرید.</p>
              <a href="/fa/contact" class="btn btn-primary">تماس با ما</a>
            </div>

            <div class="card" style="margin-top:1rem;">
              <h4>کمک می‌خواهید؟</h4>
              <p style="font-size:0.9rem;">تماس بگیرید یا پیام دهید</p>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="fa" />
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    color: white;
    padding: 4rem 0;
    position: relative;
  }

  .hero-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2rem;
  }

  .hero-visual {
    width: 300px;
    height: 300px;
    position: relative;
    z-index: 10;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 10px 30px rgba(0, 0, 0, 0.3));
  }

  .page-hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0;
  }

  .page-hero p {
    font-size: 1.25rem;
    opacity: 0.9;
    max-width: 600px;
    margin: 0;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
  }

  .main-content h3 {
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .check-list {
    list-style: none;
    padding: 0;
  }

  .check-list li {
    padding: 0.4rem 0;
    padding-right: 1.5rem;
    position: relative;
  }

  .check-list li::before {
    content: "✓";
    position: absolute;
    right: 0;
    color: var(--color-accent);
    font-weight: bold;
  }

  .feature-list {
    list-style: none;
    padding: 0;
  }

  .feature-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-bg-light);
  }

  .feature-list li:last-child {
    border-bottom: none;
  }

  .sidebar {
    position: sticky;
    top: 100px;
  }

  .cta-card {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    color: white;
    text-align: center;
  }

  .cta-card h3 {
    color: white;
    margin-bottom: 0.5rem;
  }

  .cta-card p {
    margin-bottom: 1.5rem;
    opacity: 0.9;
  }

  @media (max-width: 968px) {
    .hero-visual {
      width: 250px;
      height: 250px;
    }

    .page-hero h1 {
      font-size: 2rem;
    }

    .content-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .sidebar {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .hero-container {
      gap: 1.5rem;
    }

    .hero-visual {
      width: 200px;
      height: 200px;
    }

    .page-hero h1 {
      font-size: 1.75rem;
    }

    .page-hero p {
      font-size: 1rem;
    }
  }
</style>
