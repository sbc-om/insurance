---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import i18next from "../../lib/i18n";

await i18next.changeLanguage("fa");
---

<Layout title="بیمه شرکتی" lang="fa">
  <Header lang="fa" />

  <main>
    <section class="page-hero">
      <div class="container">
        <h1>بیمه شرکتی</h1>
        <p>پوشش شفاف برای تمام کسب‌وکارهای شما.</p>
      </div>
    </section>

    <section class="page-content">
      <div class="container card-grid">
        <div class="card">
          <h3>اموال و حوادث</h3>
          <p>محافظت از دارایی‌ها و عملیات.</p>
        </div>
        <div class="card">
          <h3>درمان و عمر گروهی</h3>
          <p>مزایای قابل اعتماد برای کارکنان.</p>
        </div>
        <div class="card">
          <h3>دریایی</h3>
          <p>پوشش برای حمل‌ونقل و کالاها.</p>
        </div>
        <div class="card">
          <h3>مسئولیت و ریسک</h3>
          <p>کاهش ریسک‌های اساسی.</p>
        </div>
        <div class="card">
          <h3>مزایای کارکنان</h3>
          <p>مزایای ساده و قدرتمند.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="fa" />
</Layout>
