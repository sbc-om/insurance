---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppInquiryForm from "../components/WhatsAppInquiryForm.astro";
import i18next from "../lib/i18n";

await i18next.changeLanguage("en");
---

<Layout title="Contact" lang="en">
  <Header lang="en" />

  <main>
    <section class="page-hero">
      <div class="container">
        <h1>Contact Us</h1>
        <p>Contact us for general information about the companies and insurance categories presented on this website.</p>
      </div>
    </section>

    <section class="page-content">
      <div class="container two-col">
        <div>
          <h2 class="section-title-alt">Contact Information</h2>
          <p class="muted">Use the details below for general website inquiries.</p>
          <div class="contact-stack" style="margin-top:1rem;">
            <div class="card contact-card">
              <h3>Website</h3>
              <p>Insurance in Oman</p>
            </div>
            <div class="card contact-card">
              <h3>Contact</h3>
              <p>Use the contact form on this page for general website inquiries.</p>
            </div>
            <div class="card contact-card">
              <h3>Location</h3>
              <p>Muscat, Oman</p>
            </div>
            <div class="card contact-card">
              <h3>Availability</h3>
              <p>General inquiries are reviewed during normal business hours.</p>
            </div>
          </div>
        </div>
        <WhatsAppInquiryForm variant="contact" phone="96891200634" />
      </div>
    </section>

    <section class="page-content">
      <div class="container card-grid">
        <div class="card">
          <h3>Scope of Contact</h3>
          <p class="muted">This contact page is intended for general website inquiries and content-related questions.</p>
        </div>
        <div class="card">
          <h3>Policies and Claims</h3>
          <p class="muted">Policy issuance, underwriting, coverage decisions, and claims remain subject to the relevant insurer's channels and procedures.</p>
        </div>
        <div class="card">
          <h3>Languages</h3>
          <p class="muted">The website content is available in English, Arabic, and Persian.</p>
        </div>
      </div>
    </section>

  </main>

  <Footer lang="en" />
</Layout>

<style>
  .contact-stack {
    display: grid;
    gap: 1rem;
  }

  .contact-card h3 {
    margin-bottom: 0.5rem;
  }
</style>
