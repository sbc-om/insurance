---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Takaful Oman Insurance - Islamic Insurance Leader | Insurance" lang="en">
  <Header lang="en" />
  
  <main>
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/takaful-oman.png" alt="Takaful Oman Insurance Logo" class="partner-logo" />
          <div class="partner-intro">
            <h1>Takaful Oman Insurance</h1>
            <p class="tagline">Leading Islamic Insurance in the Sultanate</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>About Takaful Oman</h2>
        <p>Takaful Oman Insurance SAOG is one of the pioneering Islamic insurance (Takaful) companies in the Sultanate of Oman. Established to provide Sharia-compliant insurance solutions, Takaful Oman operates under the guidance of an independent Sharia Supervisory Board ensuring all products and practices adhere to Islamic principles.</p>
        <p>Licensed by the Capital Market Authority and listed on the Muscat Securities Market, Takaful Oman combines traditional Islamic values with modern insurance expertise. The company is committed to the principles of mutual cooperation (Ta'awun) and shared responsibility, offering comprehensive protection while maintaining ethical standards.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">100%</span>
            <span class="stat-label">Sharia Compliant</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">75K+</span>
            <span class="stat-label">Participants</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">MSM</span>
            <span class="stat-label">Listed Company</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>Takaful Products</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>Motor Takaful</h3>
            <ul>
              <li>Comprehensive Takaful Cover</li>
              <li>Third Party Only</li>
              <li>Orange Card (GCC)</li>
              <li>Personal Accident Cover</li>
              <li>Agency Repairs</li>
              <li>Emergency Assistance</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>Medical Takaful</h3>
            <ul>
              <li>Individual Health Takaful</li>
              <li>Family Takaful Plans</li>
              <li>Group Medical Takaful</li>
              <li>Inpatient & Outpatient</li>
              <li>Maternity Coverage</li>
              <li>Chronic Disease Cover</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>Property Takaful</h3>
            <ul>
              <li>Home Takaful</li>
              <li>Fire & Perils Cover</li>
              <li>Contents Protection</li>
              <li>Natural Disasters</li>
              <li>Personal Liability</li>
              <li>Domestic Worker Cover</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">👨‍👩‍👧‍👦</div>
            <h3>Family Takaful</h3>
            <ul>
              <li>Life Takaful Protection</li>
              <li>Education Savings Plan</li>
              <li>Retirement Takaful</li>
              <li>Critical Illness Cover</li>
              <li>Personal Accident</li>
              <li>Hajj & Umrah Cover</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>Business Takaful</h3>
            <ul>
              <li>Property All Risks</li>
              <li>Professional Liability</li>
              <li>Workmen Compensation</li>
              <li>Money Insurance</li>
              <li>Public Liability</li>
              <li>Group Personal Accident</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">⚓</div>
            <h3>Marine Takaful</h3>
            <ul>
              <li>Cargo Takaful</li>
              <li>Hull & Machinery</li>
              <li>Freight Coverage</li>
              <li>Stock Throughput</li>
              <li>Marine Liability</li>
              <li>Boat & Yacht Cover</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>Why Choose Takaful Oman?</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">☪</span>
            <h4>Sharia Supervised</h4>
            <p>Independent Sharia Board ensures compliance with Islamic law</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Surplus Sharing</h4>
            <p>Participants share in underwriting surplus based on Takaful model</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Ethical Investing</h4>
            <p>All investments in Sharia-compliant instruments</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Local Service</h4>
            <p>Dedicated service across Oman with local expertise</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>Learn More About Takaful Oman</h2>
        <p>Contact Insurance for ethical Takaful solutions</p>
        <a href="/contact" class="cta-button">Contact for Information</a>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-left: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    left: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
