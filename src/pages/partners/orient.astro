---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Orient Insurance - UAE's Premier Insurer | Insurance" lang="en">
  <Header lang="en" />
  
  <main>
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/orient.png" alt="Orient Insurance Logo" class="partner-logo" />
          <div class="partner-intro">
            <h1>Orient Insurance</h1>
            <p class="tagline">UAE's Leading Insurance Company Since 1982</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>About Orient Insurance</h2>
        <p>Orient Insurance PJSC is one of the largest and most prestigious insurance companies in the United Arab Emirates and the wider Middle East region. Established in 1982, Orient Insurance has built an unparalleled reputation for excellence, innovation, and customer service over four decades.</p>
        <p>A member of the Al Futtaim Group, one of the region's most respected business conglomerates, Orient Insurance benefits from strong financial backing and corporate governance. The company holds the highest credit rating among insurance companies in the UAE and maintains strategic partnerships with world-leading reinsurers.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">40+</span>
            <span class="stat-label">Years of Excellence</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">A</span>
            <span class="stat-label">S&P Rating</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">$1B+</span>
            <span class="stat-label">Premium Volume</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>Insurance Products</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>Motor Insurance</h3>
            <ul>
              <li>Comprehensive Motor Cover</li>
              <li>Third Party Only</li>
              <li>Fleet Management Solutions</li>
              <li>Luxury & Sports Cars</li>
              <li>Agency Repair Network</li>
              <li>24/7 Roadside Assistance</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>Health Insurance</h3>
            <ul>
              <li>Individual Health Plans</li>
              <li>Family Health Cover</li>
              <li>Corporate Medical Insurance</li>
              <li>DHA/HAAD Compliant Plans</li>
              <li>International Coverage</li>
              <li>Wellness Programs</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>Property Insurance</h3>
            <ul>
              <li>Home Insurance</li>
              <li>Fire & Special Perils</li>
              <li>Business Property Cover</li>
              <li>Industrial All Risks</li>
              <li>Business Interruption</li>
              <li>Machinery Breakdown</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">✈️</div>
            <h3>Travel Insurance</h3>
            <ul>
              <li>Individual Travel Plans</li>
              <li>Family Travel Cover</li>
              <li>Annual Multi-Trip</li>
              <li>Schengen Visa Cover</li>
              <li>Adventure Sports</li>
              <li>COVID-19 Coverage</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>Commercial Lines</h3>
            <ul>
              <li>Professional Indemnity</li>
              <li>Directors & Officers</li>
              <li>Cyber Insurance</li>
              <li>Trade Credit</li>
              <li>Environmental Liability</li>
              <li>Product Recall</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🛡️</div>
            <h3>Specialty Lines</h3>
            <ul>
              <li>Aviation Insurance</li>
              <li>Energy & Oil Gas</li>
              <li>Marine Hull & Cargo</li>
              <li>Construction (CAR/EAR)</li>
              <li>Political Violence</li>
              <li>Surety Bonds</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>Why Choose Orient Insurance?</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Market Leader</h4>
            <p>Largest private insurer in the UAE with proven track record</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Financial Strength</h4>
            <p>Highest credit ratings among UAE insurers</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Digital Excellence</h4>
            <p>Award-winning digital platforms and mobile apps</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Claims Service</h4>
            <p>Fast, fair and efficient claims settlement</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>Learn More About Orient Insurance</h2>
        <p>Contact Insurance for premium coverage from Orient Insurance</p>
        <a href="/contact" class="cta-button">Contact for Information</a>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-left: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    left: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
