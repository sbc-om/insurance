---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="New India Assurance - India's Largest Insurer | Insurance" lang="en">
  <Header lang="en" />
  
  <main>
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/new-india.png" alt="New India Assurance Logo" class="partner-logo" />
          <div class="partner-intro">
            <h1>New India Assurance</h1>
            <p class="tagline">India's Premier Insurance Company Since 1919</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>About New India Assurance</h2>
        <p>New India Assurance Company Limited is India's largest general insurance company, established in 1919. As a wholly-owned subsidiary of the Government of India, it stands as a symbol of trust and reliability with over a century of experience in the insurance industry.</p>
        <p>With presence in 28 countries across 6 continents, New India Assurance is one of the most globally diversified Indian insurers. The company has consistently maintained its leadership position in the Indian market and has earned recognition for its financial strength, customer service excellence, and innovative products.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">100+</span>
            <span class="stat-label">Years of Trust</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">28</span>
            <span class="stat-label">Countries Worldwide</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">AAA</span>
            <span class="stat-label">IFS Rating</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>Insurance Products</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>Motor Insurance</h3>
            <ul>
              <li>Private Car Insurance</li>
              <li>Two-Wheeler Insurance</li>
              <li>Commercial Vehicle Cover</li>
              <li>Fleet Insurance Solutions</li>
              <li>Vintage Car Insurance</li>
              <li>Electric Vehicle Coverage</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>Health Insurance</h3>
            <ul>
              <li>Mediclaim Policy</li>
              <li>Critical Illness Cover</li>
              <li>Senior Citizen Health Plans</li>
              <li>Group Health Insurance</li>
              <li>Personal Accident Cover</li>
              <li>Overseas Mediclaim</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>Property Insurance</h3>
            <ul>
              <li>Householder's Policy</li>
              <li>Fire Insurance</li>
              <li>Industrial All Risks</li>
              <li>Burglary Insurance</li>
              <li>Earthquake Coverage</li>
              <li>Terrorism Risk Insurance</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">✈️</div>
            <h3>Travel Insurance</h3>
            <ul>
              <li>Overseas Travel Insurance</li>
              <li>Domestic Travel Cover</li>
              <li>Student Travel Plans</li>
              <li>Senior Citizen Travel</li>
              <li>Corporate Travel Policy</li>
              <li>Adventure Sports Cover</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>Liability Insurance</h3>
            <ul>
              <li>Public Liability</li>
              <li>Professional Indemnity</li>
              <li>Directors & Officers</li>
              <li>Product Liability</li>
              <li>Employer's Liability</li>
              <li>Environmental Liability</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">⚓</div>
            <h3>Marine Insurance</h3>
            <ul>
              <li>Marine Cargo Policy</li>
              <li>Marine Hull Insurance</li>
              <li>Inland Transit Insurance</li>
              <li>Open Cover Policy</li>
              <li>Import/Export Cover</li>
              <li>Freight Insurance</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>Why Choose New India Assurance?</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Government Backed</h4>
            <p>100% Government of India ownership ensures complete reliability</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Global Presence</h4>
            <p>International network spanning 28 countries</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Financial Security</h4>
            <p>Highest financial strength rating in the industry</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Claims Excellence</h4>
            <p>Efficient claims settlement with dedicated support</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>Learn More About New India Assurance</h2>
        <p>Contact us for general information about New India Assurance.</p>
        <a href="/contact" class="cta-button">Contact for Information</a>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-left: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    left: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
