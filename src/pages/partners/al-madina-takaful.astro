---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Al Madina Takaful - Islamic Insurance Excellence | Insurance" lang="en">
  <Header lang="en" />
  
  <main>
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/al-madina-takaful.png" alt="Al Madina Takaful Logo" class="partner-logo" />
          <div class="partner-intro">
            <h1>Al Madina Takaful</h1>
            <p class="tagline">Sharia-Compliant Insurance in Oman</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>About Al Madina Takaful</h2>
        <p>Al Madina Takaful SAOG is a premier Islamic insurance company based in the Sultanate of Oman. Licensed by the Capital Market Authority, Al Madina operates on the principles of Takaful (Islamic insurance), offering Sharia-compliant protection to individuals and businesses.</p>
        <p>The company is guided by an independent Sharia Supervisory Board comprising renowned Islamic scholars who ensure all products and operations adhere to Islamic principles. Al Madina Takaful combines traditional Islamic values with modern insurance practices to deliver comprehensive Takaful solutions.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">100%</span>
            <span class="stat-label">Sharia Compliant</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">50K+</span>
            <span class="stat-label">Policyholders</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">CMA</span>
            <span class="stat-label">Licensed</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>Takaful Products</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>Motor Takaful</h3>
            <ul>
              <li>Comprehensive Motor Takaful</li>
              <li>Third Party Only Cover</li>
              <li>Agency Repair Network</li>
              <li>Personal Accident Cover</li>
              <li>GCC Coverage Extension</li>
              <li>24/7 Roadside Assistance</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>Medical Takaful</h3>
            <ul>
              <li>Individual Health Takaful</li>
              <li>Family Health Plans</li>
              <li>Group Medical Takaful</li>
              <li>Outpatient Coverage</li>
              <li>Inpatient Benefits</li>
              <li>Maternity & Dental Cover</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>Property Takaful</h3>
            <ul>
              <li>Home Takaful Protection</li>
              <li>Fire & Perils Cover</li>
              <li>Contents Insurance</li>
              <li>Natural Disaster Cover</li>
              <li>Personal Liability</li>
              <li>Domestic Helper Cover</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">👨‍👩‍👧‍👦</div>
            <h3>Family Takaful</h3>
            <ul>
              <li>Life Takaful Plans</li>
              <li>Education Savings Takaful</li>
              <li>Retirement Planning</li>
              <li>Critical Illness Cover</li>
              <li>Personal Accident Takaful</li>
              <li>Hajj & Umrah Takaful</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>Business Takaful</h3>
            <ul>
              <li>Commercial Property Takaful</li>
              <li>Professional Indemnity</li>
              <li>Workmen's Compensation</li>
              <li>Money Insurance</li>
              <li>Fidelity Guarantee</li>
              <li>Public Liability</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">⚓</div>
            <h3>Marine Takaful</h3>
            <ul>
              <li>Marine Cargo Takaful</li>
              <li>Hull Coverage</li>
              <li>Freight Insurance</li>
              <li>Warehouse Coverage</li>
              <li>Import/Export Cover</li>
              <li>Marine Liability</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>Why Choose Al Madina Takaful?</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">☪</span>
            <h4>Fully Sharia Compliant</h4>
            <p>Supervised by independent Sharia Board of scholars</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Surplus Distribution</h4>
            <p>Policyholders share in underwriting surplus</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Ethical Investment</h4>
            <p>All funds invested in Sharia-compliant instruments</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Local Expertise</h4>
            <p>Deep understanding of Omani market needs</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>Learn More About Al Madina Takaful</h2>
        <p>Contact Insurance for ethical Takaful solutions</p>
        <a href="/contact" class="cta-button">Contact for Information</a>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-left: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    left: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
