---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Liva Insurance - Comprehensive Coverage | Insurance" lang="en">
  <Header lang="en" />
  
  <main>
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/liva.png" alt="Liva Insurance Logo" class="partner-logo" />
          <div class="partner-intro">
            <h1>Liva Insurance</h1>
            <p class="tagline">Protecting What Matters Most</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>About Liva Insurance</h2>
        <p>Liva Insurance is a prominent insurance provider in the Gulf region, formerly known as Bahrain National Insurance Company. With a rich heritage spanning several decades, Liva has evolved into a modern, customer-focused insurance company offering innovative solutions across multiple lines of business.</p>
        <p>The company operates in multiple GCC countries and is known for its strong financial standing, innovative digital platforms, and commitment to customer satisfaction. Liva Insurance is backed by strong shareholders and maintains excellent relationships with leading reinsurers worldwide.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">50+</span>
            <span class="stat-label">Years of Heritage</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">5</span>
            <span class="stat-label">GCC Countries</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">A</span>
            <span class="stat-label">Credit Rating</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>Insurance Products</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>Motor Insurance</h3>
            <ul>
              <li>Comprehensive Motor Coverage</li>
              <li>Third Party Only</li>
              <li>Orange Card (GCC Travel)</li>
              <li>New for Old Replacement</li>
              <li>Roadside Assistance</li>
              <li>Personal Accident Cover</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>Health Insurance</h3>
            <ul>
              <li>Individual Medical Plans</li>
              <li>SME Health Solutions</li>
              <li>Corporate Health Insurance</li>
              <li>Maternity Coverage</li>
              <li>Chronic Disease Management</li>
              <li>Wellness Programs</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>Home Insurance</h3>
            <ul>
              <li>Building Insurance</li>
              <li>Contents Coverage</li>
              <li>Personal Belongings</li>
              <li>Domestic Helper Cover</li>
              <li>Liability Protection</li>
              <li>Alternative Accommodation</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">✈️</div>
            <h3>Travel Insurance</h3>
            <ul>
              <li>Leisure Travel Plans</li>
              <li>Business Travel Cover</li>
              <li>Student Travel Insurance</li>
              <li>Schengen Visa Coverage</li>
              <li>Adventure Sports Cover</li>
              <li>COVID-19 Protection</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">👨‍👩‍👧‍👦</div>
            <h3>Life Insurance</h3>
            <ul>
              <li>Term Life Insurance</li>
              <li>Whole Life Plans</li>
              <li>Education Savings Plans</li>
              <li>Retirement Planning</li>
              <li>Critical Illness Cover</li>
              <li>Group Life Insurance</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>Business Insurance</h3>
            <ul>
              <li>Property All Risks</li>
              <li>Professional Indemnity</li>
              <li>Cyber Insurance</li>
              <li>Trade Credit Insurance</li>
              <li>Engineering Insurance</li>
              <li>Aviation Insurance</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>Why Choose Liva Insurance?</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Digital First</h4>
            <p>Award-winning mobile app and online portal for easy policy management</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Fast Claims</h4>
            <p>Quick and transparent claims processing with real-time tracking</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Regional Coverage</h4>
            <p>Seamless coverage across multiple GCC countries</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Expert Advice</h4>
            <p>Dedicated relationship managers for personalized service</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>Learn More About Liva Insurance</h2>
        <p>Contact us for general information about Liva Insurance.</p>
        <a href="/contact" class="cta-button">Contact for Information</a>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-left: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    left: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
