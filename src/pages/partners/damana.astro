---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Damana Insurance - Takaful Excellence | Insurance" lang="en">
  <Header lang="en" />
  
  <main>
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/damana.png" alt="Damana Insurance Logo" class="partner-logo" />
          <div class="partner-intro">
            <h1>Damana Insurance</h1>
            <p class="tagline">Sharia-Compliant Insurance Solutions</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>About Damana Insurance</h2>
        <p>Damana Insurance (formerly known as SALAMA Islamic Arab Insurance Company) is one of the pioneering Islamic insurance (Takaful) providers in the region. Established with a commitment to provide Sharia-compliant insurance products, Damana serves individuals and businesses across the GCC.</p>
        <p>The company operates under the guidance of an independent Sharia Supervisory Board ensuring all products and operations comply with Islamic principles. Damana combines traditional Islamic values with modern insurance practices to deliver comprehensive protection.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">30+</span>
            <span class="stat-label">Years in Takaful</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">200K+</span>
            <span class="stat-label">Policyholders</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">100%</span>
            <span class="stat-label">Sharia Compliant</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>Takaful Products</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>Motor Takaful</h3>
            <ul>
              <li>Comprehensive Takaful Cover</li>
              <li>Third Party Liability</li>
              <li>Agency Repairs</li>
              <li>Personal Accident Cover</li>
              <li>GCC Extension Coverage</li>
              <li>24/7 Emergency Assistance</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>Medical Takaful</h3>
            <ul>
              <li>Individual Health Takaful</li>
              <li>Family Medical Plans</li>
              <li>Corporate Health Solutions</li>
              <li>Maternity Benefits</li>
              <li>Chronic Disease Coverage</li>
              <li>International Treatment</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>Property Takaful</h3>
            <ul>
              <li>Home Takaful Protection</li>
              <li>Fire & Allied Perils</li>
              <li>Contents Coverage</li>
              <li>Natural Disaster Cover</li>
              <li>Domestic Worker Cover</li>
              <li>Personal Liability</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">👨‍👩‍👧‍👦</div>
            <h3>Family Takaful</h3>
            <ul>
              <li>Life Takaful Plans</li>
              <li>Education Savings Takaful</li>
              <li>Retirement Takaful</li>
              <li>Critical Illness Cover</li>
              <li>Personal Accident Takaful</li>
              <li>Investment-Linked Takaful</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>Business Takaful</h3>
            <ul>
              <li>Commercial Property Takaful</li>
              <li>Contractor All Risks</li>
              <li>Professional Liability</li>
              <li>Workmen Compensation</li>
              <li>Trade Credit Takaful</li>
              <li>Fidelity Guarantee</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">⚓</div>
            <h3>Marine Takaful</h3>
            <ul>
              <li>Marine Cargo Takaful</li>
              <li>Hull & Machinery</li>
              <li>Freight Insurance</li>
              <li>Marine Liability</li>
              <li>Port Operator's Cover</li>
              <li>Warehouse Coverage</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>Why Choose Damana?</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">☪</span>
            <h4>Sharia Compliant</h4>
            <p>All products approved by independent Sharia Board</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Surplus Sharing</h4>
            <p>Participate in underwriting surplus as per Takaful principles</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Ethical Investment</h4>
            <p>Funds invested in Sharia-compliant instruments only</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Expert Support</h4>
            <p>Dedicated Takaful specialists for guidance</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>Learn More About Damana</h2>
        <p>Contact Insurance for Sharia-compliant Takaful solutions</p>
        <a href="/contact" class="cta-button">Contact for Information</a>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-left: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    left: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
