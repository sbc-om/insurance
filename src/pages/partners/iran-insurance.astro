---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Iran Insurance Company - Iran's Oldest Insurer | Insurance" lang="en">
  <Header lang="en" />
  
  <main>
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/iran-insurance.png" alt="Iran Insurance Company Logo" class="partner-logo" />
          <div class="partner-intro">
            <h1>Iran Insurance Company</h1>
            <p class="tagline">Iran's Pioneer in Insurance Since 1935</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>About Iran Insurance Company</h2>
        <p>Iran Insurance Company (Bimeh Iran) is the largest and oldest insurance company in Iran, established in 1935. As a government-owned enterprise, it has played a pivotal role in developing the insurance industry in Iran and remains the market leader with the most extensive network of branches and agencies across the country.</p>
        <p>With nearly nine decades of experience, Iran Insurance Company has earned the trust of millions of policyholders. The company offers the widest range of insurance products in Iran and has expanded its operations to serve international markets, providing comprehensive coverage for diverse risks.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">90+</span>
            <span class="stat-label">Years of Service</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">30%</span>
            <span class="stat-label">Market Share</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">3000+</span>
            <span class="stat-label">Branch Network</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>Insurance Products</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>Motor Insurance</h3>
            <ul>
              <li>Comprehensive Motor Cover</li>
              <li>Third Party Liability (Bimeh Sales)</li>
              <li>Bodily Injury Cover</li>
              <li>Damage to Property</li>
              <li>Driver Personal Accident</li>
              <li>Passenger Cover</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>Health Insurance</h3>
            <ul>
              <li>Individual Health Plans</li>
              <li>Family Medical Insurance</li>
              <li>Group Health Schemes</li>
              <li>Supplementary Health Cover</li>
              <li>Critical Illness Insurance</li>
              <li>Medical Treatment Abroad</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>Property Insurance</h3>
            <ul>
              <li>Fire Insurance</li>
              <li>Earthquake Coverage</li>
              <li>Flood & Natural Disasters</li>
              <li>Theft & Burglary</li>
              <li>Business Property</li>
              <li>Industrial Risks</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">👨‍👩‍👧‍👦</div>
            <h3>Life Insurance</h3>
            <ul>
              <li>Term Life Insurance</li>
              <li>Whole Life Plans</li>
              <li>Endowment Policies</li>
              <li>Group Life Insurance</li>
              <li>Pension Plans</li>
              <li>Education Savings</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>Liability Insurance</h3>
            <ul>
              <li>Professional Liability</li>
              <li>Public Liability</li>
              <li>Employer's Liability</li>
              <li>Product Liability</li>
              <li>Contractor's Liability</li>
              <li>Medical Malpractice</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🛡️</div>
            <h3>Specialty Insurance</h3>
            <ul>
              <li>Oil & Gas Insurance</li>
              <li>Aviation Insurance</li>
              <li>Marine Cargo & Hull</li>
              <li>Construction All Risks</li>
              <li>Agricultural Insurance</li>
              <li>Livestock Insurance</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>Why Choose Iran Insurance?</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Market Leader</h4>
            <p>Largest insurer in Iran with unmatched experience</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Extensive Network</h4>
            <p>Thousands of branches and agencies nationwide</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Government Backed</h4>
            <p>Strong financial security with state ownership</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>Diverse Products</h4>
            <p>Widest range of insurance products available</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>Learn More About Iran Insurance</h2>
        <p>Contact Insurance for comprehensive coverage from Iran Insurance</p>
        <a href="/contact" class="cta-button">Contact for Information</a>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-left: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    left: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
