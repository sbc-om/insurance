---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import i18next from "../../lib/i18n";

await i18next.changeLanguage("ar");
---

<Layout title="التأمين الشخصي" lang="ar">
  <Header lang="ar" />

  <main>
    <section class="page-hero">
      <div class="container">
        <h1>التأمين الشخصي</h1>
        <p>احمِ عائلتك وصحتك وأصولك بمزايا مصممة خصيصاً.</p>
      </div>
    </section>

    <section class="page-content">
      <div class="container card-grid">
        <div class="card">
          <h3>التأمين على الحياة</h3>
          <p>أمان مالي وراحة بال لمن تحب.</p>
        </div>
        <div class="card">
          <h3>الطبي</h3>
          <p>خطط طبية مرنة مع وصول للرعاية الصحية.</p>
        </div>
        <div class="card">
          <h3>السيارات</h3>
          <p>تغطية شاملة أو ضد الغير للسيارات.</p>
        </div>
        <div class="card">
          <h3>المنزل</h3>
          <p>حماية منزلك ومحتوياته من المخاطر.</p>
        </div>
        <div class="card">
          <h3>السفر</h3>
          <p>سافر بثقة مع تغطية ومساعدة عالمية.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="ar" />
</Layout>
