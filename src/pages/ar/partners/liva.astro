---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
---

<Layout title="ليفا للتأمين | التأمين" lang="ar">
  <Header lang="ar" />
  
  <main dir="rtl">
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/liva.png" alt="شعار ليفا للتأمين" class="partner-logo" />
          <div class="partner-intro">
            <h1>ليفا للتأمين</h1>
            <p class="tagline">نحمي ما يهمك أكثر</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>عن ليفا للتأمين</h2>
        <p>ليفا للتأمين هي شركة تأمين بارزة في منطقة الخليج، كانت تُعرف سابقاً بشركة البحرين الوطنية للتأمين. مع إرث غني يمتد لعدة عقود، تطورت ليفا لتصبح شركة تأمين حديثة تركز على العملاء وتقدم حلولاً مبتكرة عبر خطوط أعمال متعددة.</p>
        <p>تعمل الشركة في عدة دول خليجية وتشتهر بقوتها المالية ومنصاتها الرقمية المبتكرة والتزامها برضا العملاء. ليفا للتأمين مدعومة من مساهمين أقوياء وتحافظ على علاقات ممتازة مع معيدي التأمين الرائدين عالمياً.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">+50</span>
            <span class="stat-label">عاماً من الإرث</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">5</span>
            <span class="stat-label">دول خليجية</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">A</span>
            <span class="stat-label">التصنيف الائتماني</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>منتجات التأمين</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>تأمين المركبات</h3>
            <ul>
              <li>تغطية شاملة للمركبات</li>
              <li>تأمين ضد الغير فقط</li>
              <li>البطاقة البرتقالية (سفر الخليج)</li>
              <li>استبدال جديد بقديم</li>
              <li>مساعدة على الطريق</li>
              <li>تغطية الحوادث الشخصية</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>التأمين الصحي</h3>
            <ul>
              <li>خطط طبية فردية</li>
              <li>حلول صحية للشركات الصغيرة والمتوسطة</li>
              <li>تأمين صحي للشركات</li>
              <li>تغطية الأمومة</li>
              <li>إدارة الأمراض المزمنة</li>
              <li>برامج العافية</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>تأمين المنازل</h3>
            <ul>
              <li>تأمين المباني</li>
              <li>تغطية المحتويات</li>
              <li>الممتلكات الشخصية</li>
              <li>تغطية العمالة المنزلية</li>
              <li>حماية المسؤولية</li>
              <li>السكن البديل</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">✈️</div>
            <h3>تأمين السفر</h3>
            <ul>
              <li>خطط السفر الترفيهي</li>
              <li>تغطية سفر الأعمال</li>
              <li>تأمين سفر الطلاب</li>
              <li>تغطية تأشيرة شنغن</li>
              <li>تغطية الرياضات المغامرة</li>
              <li>حماية كوفيد-19</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">👨‍👩‍👧‍👦</div>
            <h3>تأمين الحياة</h3>
            <ul>
              <li>تأمين الحياة المحدد المدة</li>
              <li>خطط الحياة الكاملة</li>
              <li>خطط الادخار التعليمي</li>
              <li>التخطيط للتقاعد</li>
              <li>تغطية الأمراض الحرجة</li>
              <li>تأمين الحياة الجماعي</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>تأمين الأعمال</h3>
            <ul>
              <li>جميع أخطار الممتلكات</li>
              <li>التعويض المهني</li>
              <li>التأمين السيبراني</li>
              <li>تأمين الائتمان التجاري</li>
              <li>التأمين الهندسي</li>
              <li>تأمين الطيران</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>لماذا تختار ليفا للتأمين؟</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>الرقمنة أولاً</h4>
            <p>تطبيق جوال وبوابة إلكترونية حائزة على جوائز لإدارة سهلة للوثائق</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>مطالبات سريعة</h4>
            <p>معالجة سريعة وشفافة للمطالبات مع تتبع فوري</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>تغطية إقليمية</h4>
            <p>تغطية سلسة عبر عدة دول خليجية</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>نصائح الخبراء</h4>
            <p>مديرو علاقات متخصصون للخدمة الشخصية</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>احصل على عرض أسعار من ليفا للتأمين</h2>
        <p>تواصل مع التأمين للحصول على أفضل الأسعار والتغطية من ليفا</p>
        <a href="/ar/contact" class="cta-button">اطلب معلومات</a>
      </div>
    </section>
  </main>

  <Footer lang="ar" />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-right: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    right: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
