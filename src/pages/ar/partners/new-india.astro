---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
---

<Layout title="نيو إنديا للتأمين | التأمين" lang="ar">
  <Header lang="ar" />
  
  <main dir="rtl">
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/new-india.png" alt="شعار نيو إنديا للتأمين" class="partner-logo" />
          <div class="partner-intro">
            <h1>نيو إنديا للتأمين</h1>
            <p class="tagline">شركة التأمين الهندية الأولى منذ عام 1919</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>عن نيو إنديا للتأمين</h2>
        <p>شركة نيو إنديا للتأمين المحدودة هي شركة تأمين عام تأسست عام 1919. وتعرض هذه الصفحة معلومات تعريفية عامة عن الشركة وحضورها ومنتجاتها التأمينية.</p>
        <p>مع تواجد في 28 دولة عبر 6 قارات، تعد نيو إنديا للتأمين واحدة من أكثر شركات التأمين الهندية تنوعاً عالمياً. حافظت الشركة باستمرار على موقعها الريادي في السوق الهندية واكتسبت تقديراً لقوتها المالية وتميزها في خدمة العملاء ومنتجاتها المبتكرة.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">+100</span>
            <span class="stat-label">عام من الثقة</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">28</span>
            <span class="stat-label">دولة حول العالم</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">AAA</span>
            <span class="stat-label">تصنيف IFS</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>منتجات التأمين</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>تأمين المركبات</h3>
            <ul>
              <li>تأمين السيارات الخاصة</li>
              <li>تأمين الدراجات النارية</li>
              <li>تغطية المركبات التجارية</li>
              <li>حلول تأمين الأساطيل</li>
              <li>تأمين السيارات الكلاسيكية</li>
              <li>تغطية المركبات الكهربائية</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>التأمين الصحي</h3>
            <ul>
              <li>وثيقة المطالبات الطبية</li>
              <li>تغطية الأمراض الحرجة</li>
              <li>خطط صحية لكبار السن</li>
              <li>تأمين صحي جماعي</li>
              <li>تغطية الحوادث الشخصية</li>
              <li>المطالبات الطبية الخارجية</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>تأمين الممتلكات</h3>
            <ul>
              <li>وثيقة أصحاب المنازل</li>
              <li>تأمين الحريق</li>
              <li>جميع أخطار الصناعة</li>
              <li>تأمين السرقة</li>
              <li>تغطية الزلازل</li>
              <li>تأمين مخاطر الإرهاب</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">✈️</div>
            <h3>تأمين السفر</h3>
            <ul>
              <li>تأمين السفر الخارجي</li>
              <li>تغطية السفر المحلي</li>
              <li>خطط سفر الطلاب</li>
              <li>سفر كبار السن</li>
              <li>وثيقة السفر للشركات</li>
              <li>تغطية رياضات المغامرة</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>تأمين المسؤولية</h3>
            <ul>
              <li>المسؤولية العامة</li>
              <li>التعويض المهني</li>
              <li>مسؤولية المديرين والمسؤولين</li>
              <li>مسؤولية المنتجات</li>
              <li>مسؤولية صاحب العمل</li>
              <li>المسؤولية البيئية</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">⚓</div>
            <h3>التأمين البحري</h3>
            <ul>
              <li>وثيقة البضائع البحرية</li>
              <li>تأمين الهياكل البحرية</li>
              <li>تأمين النقل الداخلي</li>
              <li>وثيقة التغطية المفتوحة</li>
              <li>تغطية الاستيراد/التصدير</li>
              <li>تأمين الشحن</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>لماذا تختار نيو إنديا للتأمين؟</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>مدعومة حكومياً</h4>
            <p>ملكية حكومية هندية بنسبة 100%</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>تواجد عالمي</h4>
            <p>شبكة دولية تمتد عبر 28 دولة</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>أمان مالي</h4>
            <p>أعلى تصنيف قوة مالية في الصناعة</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>تميز في المطالبات</h4>
            <p>تسوية فعالة للمطالبات مع دعم متخصص</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>احصل على عرض أسعار من نيو إنديا للتأمين</h2>
        <p>تواصل معنا للحصول على معلومات عامة عن نيو إنديا للتأمين</p>
        <a href="/ar/contact" class="cta-button">اطلب معلومات</a>
      </div>
    </section>
  </main>

  <Footer lang="ar" />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-right: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    right: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
