---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
---

<Layout title="شركة عمان قطر للتأمين (OQIC) | التأمين" lang="ar">
  <Header lang="ar" />
  
  <main dir="rtl">
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/oqic.png" alt="شعار شركة عمان قطر للتأمين" class="partner-logo" />
          <div class="partner-intro">
            <h1>شركة عمان قطر للتأمين (OQIC)</h1>
            <p class="tagline">معلومات تعريفية عن الشركة ومنتجاتها</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>عن شركة عمان قطر للتأمين</h2>
        <p>شركة عمان قطر للتأمين (OQIC) هي إحدى شركات التأمين الرائدة في سلطنة عمان، تأسست عام 1984. وباعتبارها مشروعاً مشتركاً بين مساهمين قطريين وعمانيين، تجمع الشركة بين الخبرة الإقليمية والمعايير الدولية لتقديم حلول تأمينية شاملة.</p>
        <p>تتمتع الشركة بخبرة طويلة في السوق العماني، وتعرض هذه الصفحة معلومات تعريفية عامة عن الشركة ومنتجاتها التأمينية وإطارها المؤسسي.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">+40</span>
            <span class="stat-label">عاماً من الخبرة</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">+100 ألف</span>
            <span class="stat-label">عميل راضٍ</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">A-</span>
            <span class="stat-label">التصنيف المالي</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>منتجات التأمين</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>تأمين المركبات</h3>
            <ul>
              <li>تأمين شامل للمركبات</li>
              <li>تأمين ضد الغير</li>
              <li>تأمين الأساطيل</li>
              <li>تأمين المركبات التجارية</li>
              <li>مساعدة على الطريق على مدار الساعة</li>
              <li>شبكة إصلاح معتمدة</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>التأمين الصحي</h3>
            <ul>
              <li>خطط صحية فردية</li>
              <li>تغطية صحية عائلية</li>
              <li>تأمين طبي للشركات</li>
              <li>تغطية العيادات الخارجية والداخلية</li>
              <li>مزايا طب الأسنان والبصريات</li>
              <li>خيارات العلاج الدولية</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>تأمين الممتلكات</h3>
            <ul>
              <li>تأمين المنازل</li>
              <li>تغطية الحريق والأخطار</li>
              <li>تأمين المحتويات</li>
              <li>الحماية من الكوارث الطبيعية</li>
              <li>تأمين المؤجرين</li>
              <li>تأمين المستأجرين</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">✈️</div>
            <h3>تأمين السفر</h3>
            <ul>
              <li>تغطية الرحلة الواحدة</li>
              <li>خطط الرحلات المتعددة السنوية</li>
              <li>تغطية الطوارئ الطبية</li>
              <li>حماية إلغاء الرحلة</li>
              <li>تغطية فقدان الأمتعة</li>
              <li>مساعدة عالمية</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>التأمين التجاري</h3>
            <ul>
              <li>تأمين ممتلكات الأعمال</li>
              <li>المسؤولية المهنية</li>
              <li>تأمين المسؤولية العامة</li>
              <li>تعويضات العمال</li>
              <li>انقطاع الأعمال</li>
              <li>مسؤولية المديرين والمسؤولين</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">⚓</div>
            <h3>التأمين البحري</h3>
            <ul>
              <li>تأمين البضائع</li>
              <li>تأمين الهياكل</li>
              <li>المسؤولية البحرية</li>
              <li>تأمين الشحن</li>
              <li>مسؤولية مشغلي الموانئ</li>
              <li>تأمين اليخوت</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>لماذا تختار شركة عمان قطر للتأمين؟</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>تسوية سريعة للمطالبات</h4>
            <p>معالجة فعالة للمطالبات مع فريق دعم متخصص</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>شبكة واسعة</h4>
            <p>شبكة واسعة من الكراجات والمستشفيات ومقدمي الخدمات</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>خدمات رقمية</h4>
            <p>شراء وتجديد وتتبع المطالبات عبر الإنترنت</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>دعم على مدار الساعة</h4>
            <p>خدمة عملاء ومساعدة طوارئ على مدار الساعة</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>احصل على عرض أسعار من شركة عمان قطر للتأمين</h2>
        <p>تواصل مع التأمين للحصول على أفضل الأسعار والتغطية</p>
        <a href="/ar/contact" class="cta-button">اطلب معلومات</a>
      </div>
    </section>
  </main>

  <Footer lang="ar" />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-right: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    right: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
