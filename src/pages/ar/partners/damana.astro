---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
---

<Layout title="ضمانة للتأمين التكافلي | التأمين" lang="ar">
  <Header lang="ar" />
  
  <main dir="rtl">
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/damana.png" alt="شعار ضمانة للتأمين" class="partner-logo" />
          <div class="partner-intro">
            <h1>ضمانة للتأمين</h1>
            <p class="tagline">حلول تأمينية متوافقة مع الشريعة الإسلامية</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>عن ضمانة للتأمين</h2>
        <p>ضمانة للتأمين (المعروفة سابقاً بشركة سلامة للتأمين الإسلامي العربي) هي إحدى الشركات الرائدة في مجال التأمين الإسلامي (التكافل) في المنطقة. تأسست بالتزام بتقديم منتجات تأمينية متوافقة مع الشريعة الإسلامية، وتخدم ضمانة الأفراد والشركات في جميع أنحاء دول مجلس التعاون الخليجي.</p>
        <p>تعمل الشركة تحت إشراف هيئة رقابة شرعية مستقلة تضمن توافق جميع المنتجات والعمليات مع المبادئ الإسلامية. تجمع ضمانة بين القيم الإسلامية التقليدية والممارسات التأمينية الحديثة لتقديم حماية شاملة.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">+30</span>
            <span class="stat-label">عاماً في التكافل</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">+200 ألف</span>
            <span class="stat-label">حامل وثيقة</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">100%</span>
            <span class="stat-label">متوافق مع الشريعة</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>منتجات التكافل</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>تكافل المركبات</h3>
            <ul>
              <li>تغطية تكافلية شاملة</li>
              <li>تأمين ضد الغير</li>
              <li>إصلاحات الوكالة</li>
              <li>تغطية الحوادث الشخصية</li>
              <li>تغطية امتداد دول الخليج</li>
              <li>مساعدة طوارئ على مدار الساعة</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>التكافل الطبي</h3>
            <ul>
              <li>تكافل صحي فردي</li>
              <li>خطط طبية عائلية</li>
              <li>حلول صحية للشركات</li>
              <li>مزايا الأمومة</li>
              <li>تغطية الأمراض المزمنة</li>
              <li>العلاج الدولي</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>تكافل الممتلكات</h3>
            <ul>
              <li>حماية تكافلية للمنزل</li>
              <li>الحريق والأخطار المصاحبة</li>
              <li>تغطية المحتويات</li>
              <li>تغطية الكوارث الطبيعية</li>
              <li>تغطية العمالة المنزلية</li>
              <li>المسؤولية الشخصية</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">👨‍👩‍👧‍👦</div>
            <h3>التكافل العائلي</h3>
            <ul>
              <li>خطط تكافل الحياة</li>
              <li>تكافل الادخار التعليمي</li>
              <li>تكافل التقاعد</li>
              <li>تغطية الأمراض الحرجة</li>
              <li>تكافل الحوادث الشخصية</li>
              <li>تكافل مرتبط بالاستثمار</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>تكافل الأعمال</h3>
            <ul>
              <li>تكافل الممتلكات التجارية</li>
              <li>جميع أخطار المقاولين</li>
              <li>المسؤولية المهنية</li>
              <li>تعويضات العمال</li>
              <li>تكافل الائتمان التجاري</li>
              <li>ضمان الأمانة</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">⚓</div>
            <h3>التكافل البحري</h3>
            <ul>
              <li>تكافل البضائع البحرية</li>
              <li>الهياكل والآلات</li>
              <li>تأمين الشحن</li>
              <li>المسؤولية البحرية</li>
              <li>تغطية مشغلي الموانئ</li>
              <li>تغطية المستودعات</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>لماذا تختار ضمانة؟</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">☪</span>
            <h4>متوافق مع الشريعة</h4>
            <p>جميع المنتجات معتمدة من هيئة شرعية مستقلة</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>المشاركة في الفائض</h4>
            <p>المشاركة في فائض الاكتتاب وفق مبادئ التكافل</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>استثمار أخلاقي</h4>
            <p>الأموال مستثمرة في أدوات متوافقة مع الشريعة فقط</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>دعم متخصص</h4>
            <p>متخصصون في التكافل للإرشاد والتوجيه</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>احصل على عرض أسعار من ضمانة</h2>
        <p>تواصل مع التأمين للحصول على حلول تكافلية متوافقة مع الشريعة</p>
        <a href="/ar/contact" class="cta-button">اطلب معلومات</a>
      </div>
    </section>
  </main>

  <Footer lang="ar" />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-right: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    right: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
