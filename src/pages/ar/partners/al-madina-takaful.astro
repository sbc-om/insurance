---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
---

<Layout title="المدينة للتكافل | التأمين" lang="ar">
  <Header lang="ar" />
  
  <main dir="rtl">
    <section class="partner-hero">
      <div class="container">
        <div class="partner-header">
          <img src="/images/alliances/al-madina-takaful.png" alt="شعار المدينة للتكافل" class="partner-logo" />
          <div class="partner-intro">
            <h1>المدينة للتكافل</h1>
            <p class="tagline">التأمين الإسلامي المتوافق مع الشريعة في عُمان</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-about">
      <div class="container">
        <h2>عن المدينة للتكافل</h2>
        <p>المدينة للتكافل ش.م.ع.ع هي شركة تأمين إسلامية رائدة مقرها في سلطنة عُمان. مرخصة من هيئة سوق المال، تعمل المدينة وفق مبادئ التكافل (التأمين الإسلامي)، وتقدم حماية متوافقة مع الشريعة للأفراد والشركات.</p>
        <p>تُدار الشركة بتوجيه من هيئة رقابة شرعية مستقلة تضم علماء إسلاميين مرموقين يضمنون التزام جميع المنتجات والعمليات بالمبادئ الإسلامية. تجمع المدينة للتكافل بين القيم الإسلامية التقليدية والممارسات التأمينية الحديثة لتقديم حلول تكافلية شاملة.</p>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-number">100%</span>
            <span class="stat-label">متوافق مع الشريعة</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">+50 ألف</span>
            <span class="stat-label">حامل وثيقة</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">CMA</span>
            <span class="stat-label">مرخصة</span>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-products">
      <div class="container">
        <h2>منتجات التكافل</h2>
        
        <div class="products-grid">
          <div class="product-card">
            <div class="product-icon">🚗</div>
            <h3>تكافل المركبات</h3>
            <ul>
              <li>تكافل شامل للمركبات</li>
              <li>تغطية ضد الغير فقط</li>
              <li>شبكة إصلاح الوكالة</li>
              <li>تغطية الحوادث الشخصية</li>
              <li>امتداد تغطية دول الخليج</li>
              <li>مساعدة على الطريق على مدار الساعة</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏥</div>
            <h3>التكافل الطبي</h3>
            <ul>
              <li>تكافل صحي فردي</li>
              <li>خطط صحية عائلية</li>
              <li>تكافل طبي جماعي</li>
              <li>تغطية العيادات الخارجية</li>
              <li>مزايا العيادات الداخلية</li>
              <li>تغطية الأمومة وطب الأسنان</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏠</div>
            <h3>تكافل الممتلكات</h3>
            <ul>
              <li>حماية تكافلية للمنزل</li>
              <li>تغطية الحريق والأخطار</li>
              <li>تأمين المحتويات</li>
              <li>تغطية الكوارث الطبيعية</li>
              <li>المسؤولية الشخصية</li>
              <li>تغطية العمالة المنزلية</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">👨‍👩‍👧‍👦</div>
            <h3>التكافل العائلي</h3>
            <ul>
              <li>خطط تكافل الحياة</li>
              <li>تكافل الادخار التعليمي</li>
              <li>التخطيط للتقاعد</li>
              <li>تغطية الأمراض الحرجة</li>
              <li>تكافل الحوادث الشخصية</li>
              <li>تكافل الحج والعمرة</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">🏢</div>
            <h3>تكافل الأعمال</h3>
            <ul>
              <li>تكافل الممتلكات التجارية</li>
              <li>التعويض المهني</li>
              <li>تعويضات العمال</li>
              <li>تأمين الأموال</li>
              <li>ضمان الأمانة</li>
              <li>المسؤولية العامة</li>
            </ul>
          </div>

          <div class="product-card">
            <div class="product-icon">⚓</div>
            <h3>التكافل البحري</h3>
            <ul>
              <li>تكافل البضائع البحرية</li>
              <li>تغطية الهياكل</li>
              <li>تأمين الشحن</li>
              <li>تغطية المستودعات</li>
              <li>تغطية الاستيراد/التصدير</li>
              <li>المسؤولية البحرية</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-features">
      <div class="container">
        <h2>لماذا تختار المدينة للتكافل؟</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">☪</span>
            <h4>متوافق كلياً مع الشريعة</h4>
            <p>تحت إشراف هيئة شرعية مستقلة من العلماء</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>توزيع الفائض</h4>
            <p>يشارك حاملو الوثائق في فائض الاكتتاب</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>استثمار أخلاقي</h4>
            <p>جميع الأموال مستثمرة في أدوات متوافقة مع الشريعة</p>
          </div>
          <div class="feature">
            <span class="feature-icon">✓</span>
            <h4>خبرة محلية</h4>
            <p>فهم عميق لاحتياجات السوق العماني</p>
          </div>
        </div>
      </div>
    </section>

    <section class="partner-cta">
      <div class="container">
        <h2>احصل على عرض أسعار من المدينة للتكافل</h2>
        <p>تواصل مع التأمين للحصول على حلول تكافلية أخلاقية</p>
        <a href="/ar/contact" class="cta-button">اطلب معلومات</a>
      </div>
    </section>
  </main>

  <Footer lang="ar" />
</Layout>

<style>
  .partner-hero {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 4rem 0;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-logo {
    width: 150px;
    height: 150px;
    object-fit: contain;
    background: white;
    border-radius: 1rem;
    padding: 1rem;
  }

  .partner-intro h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 2rem;
    color: #1a365d;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partner-about p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5568;
    max-width: 900px;
    margin: 0 auto 1rem;
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    padding: 2rem;
    border-radius: 1rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 1rem;
    opacity: 0.9;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .product-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .product-card h3 {
    color: #1a365d;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .product-card ul {
    list-style: none;
    padding: 0;
  }

  .product-card li {
    padding: 0.5rem 0;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    position: relative;
    padding-right: 1.5rem;
  }

  .product-card li:before {
    content: "•";
    color: #3182ce;
    position: absolute;
    right: 0;
    font-weight: bold;
  }

  .product-card li:last-child {
    border-bottom: none;
  }

  .partner-products {
    background: #f7fafc;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    text-align: center;
    padding: 2rem;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #48bb78;
    color: white;
    border-radius: 50%;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature h4 {
    color: #1a365d;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #718096;
  }

  .partner-cta {
    background: linear-gradient(135deg, #1a365d 0%, #2d5a87 100%);
    color: white;
    text-align: center;
  }

  .partner-cta h2 {
    color: white;
  }

  .partner-cta p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    background: #48bb78;
    color: white;
    padding: 1rem 3rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-button:hover {
    background: #38a169;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      text-align: center;
    }

    .partner-intro h1 {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
