---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import i18next from "../../lib/i18n";

await i18next.changeLanguage("ar");
---

<Layout title="تأمين الشركات" lang="ar">
  <Header lang="ar" />

  <main>
    <section class="page-hero">
      <div class="container">
        <h1>تأمين الشركات</h1>
        <p>تغطية واضحة لكل أعمالك.</p>
      </div>
    </section>

    <section class="page-content">
      <div class="container card-grid">
        <div class="card">
          <h3>الممتلكات والحوادث</h3>
          <p>حماية الأصول والتشغيل.</p>
        </div>
        <div class="card">
          <h3>الطبي الجماعي والحياة</h3>
          <p>معلومات واضحة حول مزايا الموظفين.</p>
        </div>
        <div class="card">
          <h3>البحري</h3>
          <p>تغطية للشحنات والبضائع.</p>
        </div>
        <div class="card">
          <h3>المسؤولية والمخاطر</h3>
          <p>تقليل المخاطر الأساسية.</p>
        </div>
        <div class="card">
          <h3>مزايا الموظفين</h3>
          <p>مزايا بسيطة وقوية.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="ar" />
</Layout>
