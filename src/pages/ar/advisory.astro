---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import i18next from "../../lib/i18n";

await i18next.changeLanguage("ar");
---

<Layout title="الخدمات الاستشارية" lang="ar">
  <Header lang="ar" />

  <main>
    <section class="page-hero">
      <div class="container">
        <h1>الخدمات الاستشارية</h1>
        <p>نصح واضح وتغطية أفضل.</p>
      </div>
    </section>

    <section class="page-content">
      <div class="container card-grid">
        <div class="card">
          <h3>خطط مخصصة</h3>
          <p>خطط مناسبة لك.</p>
        </div>
        <div class="card">
          <h3>تدقيق التأمين</h3>
          <p>مراجعة ما لديك.</p>
        </div>
        <div class="card">
          <h3>تقييم المخاطر</h3>
          <p>تحديد المخاطر وتقليلها.</p>
        </div>
        <div class="card">
          <h3>الاتصال التأميني الدولي</h3>
          <p>تغطية إقليمية وعالمية.</p>
        </div>
        <div class="card">
          <h3>الدفاع عن المطالبات</h3>
          <p>دعم عند المطالبة.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="ar" />
</Layout>
