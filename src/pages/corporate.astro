---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import i18next from "../lib/i18n";

await i18next.changeLanguage("en");
---

<Layout title="Corporate Insurance" lang="en">
  <Header lang="en" />

  <main>
    <section class="page-hero">
      <div class="container">
        <h1>Corporate Insurance</h1>
        <p>Clear cover for every business.</p>
      </div>
    </section>

    <section class="page-content">
      <div class="container card-grid">
        <div class="card">
          <h3>Property & Casualty</h3>
          <p>Protect assets and operations.</p>
        </div>
        <div class="card">
          <h3>Group Medical & Life</h3>
          <p>Benefits your team can trust.</p>
        </div>
        <div class="card">
          <h3>Marine</h3>
          <p>Cover for shipments and cargo.</p>
        </div>
        <div class="card">
          <h3>Liability & Risk</h3>
          <p>Protection from key risks.</p>
        </div>
        <div class="card">
          <h3>Employee Benefits</h3>
          <p>Simple, strong benefits.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>
