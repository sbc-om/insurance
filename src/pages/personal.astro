---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import i18next from "../lib/i18n";

await i18next.changeLanguage("en");
---

<Layout title="Personal Insurance" lang="en">
  <Header lang="en" />

  <main>
    <section class="page-hero">
      <div class="container">
        <h1>Personal Insurance</h1>
        <p>Protect your family, health, assets, and future with tailored coverage.</p>
      </div>
    </section>

    <section class="page-content">
      <div class="container card-grid">
        <div class="card">
          <h3>Life Insurance</h3>
          <p>Financial security and peace of mind for your loved ones.</p>
        </div>
        <div class="card">
          <h3>Medical</h3>
          <p>Access quality healthcare with flexible medical plans.</p>
        </div>
        <div class="card">
          <h3>Car</h3>
          <p>Comprehensive and third‑party motor coverage.</p>
        </div>
        <div class="card">
          <h3>Home</h3>
          <p>Protect your home and contents against unexpected risks.</p>
        </div>
        <div class="card">
          <h3>Travel</h3>
          <p>Travel confidently with global coverage and assistance.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>
