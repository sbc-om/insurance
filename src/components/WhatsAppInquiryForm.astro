---
interface Props {
  variant: "contact" | "support";
  phone: string;
  lang?: "en" | "ar" | "fa";
}

type InputField = {
  name: string;
  label: string;
  type: "text" | "tel" | "email";
  placeholder: string;
  required: boolean;
};

type TextareaField = {
  name: string;
  label: string;
  type: "textarea";
  placeholder: string;
  required: boolean;
};

type FormField = InputField | TextareaField;

type FormContent = {
  title: string;
  description: string;
  helper: string;
  button: string;
  status: string;
  fields: FormField[];
};

type LocalizedContentMap = Record<NonNullable<Props["lang"]>, Record<Props["variant"], FormContent>>;

const { variant, phone, lang = "en" } = Astro.props;

const contentMap: LocalizedContentMap = {
