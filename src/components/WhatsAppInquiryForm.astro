      helper: "Your details stay in your browser until you choose to send the message in WhatsApp.",
      button: "Continue in WhatsApp",
      status: "WhatsApp is opening with your message draft.",
      fields: [
        { name: "fullName", label: "Full name", type: "text", placeholder: "Your full name", required: true },
        { name: "phone", label: "Phone", type: "tel", placeholder: "Your phone number", required: true },
        { name: "subject", label: "Subject", type: "text", placeholder: "What is this about?", required: true },
        { name: "message", label: "Message", type: "textarea", placeholder: "Tell us how we can help.", required: true },
      ],
    },
    support: {
      title: "Request support",
      description: "Share your support request and we will prepare a structured WhatsApp message for you.",
      helper: "After submitting, WhatsApp opens in a new tab with your message pre-filled and ready to send.",
      button: "Send via WhatsApp",
      status: "WhatsApp is opening with your support request.",
      fields: [
        { name: "fullName", label: "Full name", type: "text", placeholder: "Your full name", required: true },
        { name: "email", label: "Email", type: "email", placeholder: "your@email.com", required: true },
        { name: "phone", label: "Phone", type: "tel", placeholder: "Your phone number", required: true },
        { name: "message", label: "How can we help?", type: "textarea", placeholder: "Describe your issue or question.", required: true },
      ],
    },
  },
  ar: {
    contact: {
      title: "أرسل استفسارًا",
