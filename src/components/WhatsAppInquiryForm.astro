      helper: "تبقى بياناتك داخل المتصفح حتى تختار إرسال الرسالة عبر واتساب.",
      button: "المتابعة عبر واتساب",
      status: "يتم الآن فتح واتساب مع مسودة رسالتك.",
      fields: [
        { name: "fullName", label: "الاسم الكامل", type: "text", placeholder: "اكتب اسمك الكامل", required: true },
        { name: "phone", label: "رقم الهاتف", type: "tel", placeholder: "اكتب رقم هاتفك", required: true },
        { name: "subject", label: "الموضوع", type: "text", placeholder: "ما موضوع الرسالة؟", required: true },
        { name: "message", label: "الرسالة", type: "textarea", placeholder: "أخبرنا كيف يمكننا مساعدتك.", required: true },
      ],
    },
    support: {
      title: "طلب دعم",
      description: "شارك طلب الدعم الخاص بك وسنجهز لك رسالة واتساب منظمة وجاهزة للإرسال.",
      helper: "بعد الإرسال، يفتح واتساب في تبويب جديد مع رسالتك مكتملة وجاهزة للإرسال.",
      button: "إرسال عبر واتساب",
      status: "يتم الآن فتح واتساب مع طلب الدعم الخاص بك.",
      fields: [
        { name: "fullName", label: "الاسم الكامل", type: "text", placeholder: "اكتب اسمك الكامل", required: true },
        { name: "email", label: "البريد الإلكتروني", type: "email", placeholder: "name@example.com", required: true },
